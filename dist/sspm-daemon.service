[Unit]
Description=SSPM REST API Daemon
Documentation=https://github.com/Riu-Mahiyo/ShioSakura-Package-Manager-SSPM-
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/sspm-daemon
Restart=on-failure
RestartSec=5
Environment=SSPM_DAEMON_PORT=7373

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/sspm /home

[Install]
WantedBy=multi-user.target
